//Problem: Given weighted graph with non-negative edges, compute shortest path from source using priority queue.
#include <stdio.h>
#include <limits.h>

#define MAX 100

int n;
int adj[MAX][MAX];

// Structure for priority queue
struct Node {
    int vertex;
    int dist;
};

struct Node pq[MAX];
int size = 0;

// Swap
void swap(struct Node *a, struct Node *b) {
    struct Node temp = *a;
    *a = *b;
    *b = temp;
}

// Min Heapify
void heapify(int i) {
    int smallest = i;
    int left = 2*i + 1;
    int right = 2*i + 2;

    if (left < size && pq[left].dist < pq[smallest].dist)
        smallest = left;

    if (right < size && pq[right].dist < pq[smallest].dist)
        smallest = right;

    if (smallest != i) {
        swap(&pq[i], &pq[smallest]);
        heapify(smallest);
    }
}

// Insert into PQ
void push(int v, int d) {
    int i = size++;
    pq[i].vertex = v;
    pq[i].dist = d;

    while (i != 0 && pq[(i-1)/2].dist > pq[i].dist) {
        swap(&pq[i], &pq[(i-1)/2]);
        i = (i-1)/2;
    }
}

// Extract min
struct Node pop() {
    struct Node root = pq[0];
    pq[0] = pq[--size];
    heapify(0);
    return root;
}

// Dijkstra
void dijkstra(int src) {
    int dist[MAX];
    int visited[MAX] = {0};

    for (int i = 0; i < n; i++)
        dist[i] = INT_MAX;

    dist[src] = 0;
    push(src, 0);

    while (size > 0) {
        struct Node node = pop();
        int u = node.vertex;

        if (visited[u]) continue;
        visited[u] = 1;

        for (int v = 0; v < n; v++) {
            if (adj[u][v] && !visited[v]) {
                if (dist[u] + adj[u][v] < dist[v]) {
                    dist[v] = dist[u] + adj[u][v];
                    push(v, dist[v]);
                }
            }
        }
    }

    printf("Shortest distances from source:\n");
    for (int i = 0; i < n; i++) {
        printf("Node %d : %d\n", i, dist[i]);
    }
}

int main() {
    int src;

    printf("Enter number of vertices: ");
    scanf("%d", &n);

    printf("Enter adjacency matrix (0 if no edge):\n");
    for (int i = 0; i < n; i++) {
        for (int j = 0; j < n; j++) {
            scanf("%d", &adj[i][j]);
        }
    }

    printf("Enter source vertex: ");
    scanf("%d", &src);

    dijkstra(src);

    return 0;
}
