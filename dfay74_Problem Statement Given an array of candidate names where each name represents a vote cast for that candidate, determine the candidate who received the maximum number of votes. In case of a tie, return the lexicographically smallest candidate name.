//Problem StatementGiven an array of candidate names where each name represents a vote cast for that candidate, determine the candidate who received the maximum number of votes. In case of a tie, return the lexicographically smallest candidate name.
#include <stdio.h>
#include <string.h>

#define MAX 1000
#define NAME_LEN 50

typedef struct {
    char name[NAME_LEN];
    int count;
} Candidate;

int main() {
    int n;
    scanf("%d", &n);

    char votes[MAX][NAME_LEN];
    for (int i = 0; i < n; i++) {
        scanf("%s", votes[i]);
    }

    Candidate candidates[MAX];
    int size = 0;

    // Count votes
    for (int i = 0; i < n; i++) {
        int found = 0;

        for (int j = 0; j < size; j++) {
            if (strcmp(candidates[j].name, votes[i]) == 0) {
                candidates[j].count++;
                found = 1;
                break;
            }
        }

        if (!found) {
            strcpy(candidates[size].name, votes[i]);
            candidates[size].count = 1;
            size++;
        }
    }

    // Find winner
    char winner[NAME_LEN];
    int maxVotes = 0;

    for (int i = 0; i < size; i++) {
        if (candidates[i].count > maxVotes) {
            maxVotes = candidates[i].count;
            strcpy(winner, candidates[i].name);
        }
        else if (candidates[i].count == maxVotes) {
            if (strcmp(candidates[i].name, winner) < 0) {
                strcpy(winner, candidates[i].name);
            }
        }
    }

    printf("%s %d\n", winner, maxVotes);

    return 0;
}
